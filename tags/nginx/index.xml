<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Nginx on</title><link>https://b.cornradio.org/tags/nginx/</link><description>Recent content in Nginx on</description><generator>Hugo -- gohugo.io</generator><language>zh-cn</language><lastBuildDate>Tue, 26 Mar 2024 00:00:00 +0000</lastBuildDate><atom:link href="https://b.cornradio.org/tags/nginx/index.xml" rel="self" type="application/rss+xml"/><item><title>nginx配置https(certbot)</title><link>https://b.cornradio.org/p/nginxhttpswithcertbot/</link><pubDate>Tue, 26 Mar 2024 00:00:00 +0000</pubDate><guid>https://b.cornradio.org/p/nginxhttpswithcertbot/</guid><description>&lt;img src="https://b.cornradio.org/certbot.jpg" alt="Featured image of post nginx配置https(certbot)" />&lt;h2 id="安装nginx">安装nginx
&lt;/h2>&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-fallback" data-lang="fallback">&lt;span class="line">&lt;span class="cl">apt install nginx -y
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;p>nginx 默认html文件位置&lt;/p>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-gdscript3" data-lang="gdscript3">&lt;span class="line">&lt;span class="cl">&lt;span class="o">/&lt;/span>&lt;span class="k">var&lt;/span>&lt;span class="o">/&lt;/span>&lt;span class="n">www&lt;/span>&lt;span class="o">/&lt;/span>&lt;span class="n">html&lt;/span>&lt;span class="o">/&lt;/span>
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h2 id="用certbot自动配置">用certbot自动配置
&lt;/h2>&lt;p>&lt;a class="link" href="https://certbot.eff.org/instructions?ws=nginx&amp;amp;os=ubuntufocal" target="_blank" rel="noopener"
>certbot&lt;/a>&lt;/p>
&lt;p>用certbot安装会需要输入邮箱，但是其他的都是自动化的，很方便。&lt;/p>
&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-fallback" data-lang="fallback">&lt;span class="line">&lt;span class="cl">sudo snap install --classic certbot
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">#测试安装，不消耗额度,但是证书会提示有危险(私签)
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">sudo certbot --nginx --test-cert
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">#真实安装
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">sudo certbot --nginx
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h3 id="重启nginx">重启nginx
&lt;/h3>&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-fallback" data-lang="fallback">&lt;span class="line">&lt;span class="cl">nginx -t
&lt;/span>&lt;/span>&lt;span class="line">&lt;span class="cl">sudo systemctl restart nginx
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;h2 id="开启防火墙允许">开启防火墙允许
&lt;/h2>&lt;div class="highlight">&lt;pre tabindex="0" class="chroma">&lt;code class="language-fallback" data-lang="fallback">&lt;span class="line">&lt;span class="cl">ufw allow 443
&lt;/span>&lt;/span>&lt;/code>&lt;/pre>&lt;/div></description></item></channel></rss>